# Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# CLERK AUTHENTICATION (Required)
# ===========================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ===========================================
# LLM PROVIDERS (Required at least one)
# ===========================================
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# MONGODB DATABASE (Required)
# ===========================================
# Local: mongodb://localhost:27017/dandeli_travel
# Atlas: mongodb+srv://username:password@cluster.xxx.mongodb.net/dandeli_travel
MONGODB_URI=mongodb://localhost:27017/dandeli_travel

# ===========================================
# TWILIO SMS (Optional - for booking notifications)
# ===========================================
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
DESTINATION_PHONE_NUMBER=+0987654321

# ===========================================
# CORS SETTINGS (For production)
# ===========================================
# Comma-separated list of allowed origins
# Example: https://your-domain.com,https://another-domain.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===========================================
# PINECONE VECTOR SEARCH (Optional)
# ===========================================
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=dandeli-travel

# ===========================================
# API URL (For frontend to connect to backend)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000